  // ── OrphanEtypes ────────────────────────────────────────────────
  "OrphanEtypes": [
    {
      "etype": "aphid",
      "label": "Aphid",
      "category": "Hidden",
      "parent": "process-drawable",
      "spawnable": false,
      "description": "The aphid lurker is an insectoid lurker enemy in The Precursor Legacy. They spawn from the dark eco plant to defend it during the mission \"Defeat the dark eco plant\" within the Forbidden Temple."
    },
    {
      "etype": "helix-button",
      "label": "Helix Button",
      "category": "Hidden",
      "parent": "process-drawable",
      "spawnable": false,
      "link_slots": [
