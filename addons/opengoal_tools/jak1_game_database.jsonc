    {
      "etype": "lurker-shark",
      "label": "Lurker Shark",
      "category": "Hidden",
      "parent": "process-drawable",
      "spawnable": false,
      "description": "The lurker shark is a large orange shark-like creature inhabiting the oceans in The Precursor Legacy, serving as the game's invisible wall mechanism to prevent the player from moving too far into the water."
    },
    {
      "etype": "rolling-lightning-mole",
      "label": "Rolling Lightning Mole",
      "category": "Hidden",
      "parent": "process-drawable",
      "spawnable": false,
      "description": "The lightning mole is a medium-sized subterranean animal in The Precursor Legacy. Scared out of their holes by a band of lurker robbers — Jak must herd them back into their holes in Precursor Basin."
    },
    {
      "etype": "rolling-robber",
      "label": "Rolling Robber",
      "category": "Hidden",
      "parent": "process-drawable",
      "spawnable": false,
      "description": "The robber is a lurker enemy in The Precursor Legacy, found in Precursor Basin. Robbers scared the rare lightning moles out of their underground holes — Jak must drive them off to restore order."
    },
    {
      "etype": "snow-log",
      "label": "Snow Log",
      "category": "Hidden",
      "parent": "process-drawable",
      "spawnable": false,
      "link_slots": [
        {
          "lump_key": "alt-actor",
          "slot": 0,
          "label": "Snow log master controller",
          "accepts": [
            "any"
          ],
          "required": true
        }
      ]
    },
    {
      "etype": "snow-log-button",
      "label": "Snow Log Button",
      "category": "Hidden",
      "parent": "process-drawable",
      "spawnable": false,
      "link_slots": [
        {
          "lump_key": "alt-actor",
          "slot": 0,
          "label": "Snow log to activate",
          "accepts": [
            "snow-log"
          ],
          "required": true
        }
      ]
    },
    {
      "etype": "snow-ram-boss",
      "label": "Snow Ram Boss",
      "category": "Hidden",
      "parent": "process-drawable",
      "spawnable": false,
      "description": "The ice lurker, also known as the ice monster, is an enemy in The Precursor Legacy, spawning from the slippery ice regions of Snowy Mountain."
    }
  ],

