      "id": "meters",
      "label": "meters",
      "description": "Single float, scaled × 4096. Use for distances in metres"
    },
    {
      "id": "degrees",
      "label": "degrees",
      "description": "Single float, scaled × 182.044. Use for angles in degrees"
    },
    {
      "id": "int32",
      "label": "int32",
      "description": "Signed 32-bit int array — space-separate multiple values"
    },
    {
      "id": "uint32",
      "label": "uint32",
      "description": "Unsigned 32-bit int array — space-separate multiple values"
    },
    {
      "id": "enum-int32",
      "label": "enum-int32",
      "description": "GOAL enum resolved to int32 e.g. '(game-task village1-yakow)'"
    },
    {
      "id": "enum-uint32",
      "label": "enum-uint32",
      "description": "GOAL enum resolved to uint32 e.g. '(fact-options has-power-cell)'"
    },
    {
      "id": "vector4m",
      "label": "vector4m",
      "description": "4-component vector, each × 4096 — 'x y z w'"
    },
    {
      "id": "vector3m",
      "label": "vector3m",
      "description": "3-component vector, each × 4096, w=1 — 'x y z'"
    },
    {
      "id": "vector-vol",
      "label": "vector-vol",
      "description": "Volume vector: 'x y z radius_m' (xyz raw, w × 4096)"
    },
    {
      "id": "vector",
      "label": "vector",
      "description": "4-component raw vector — 'x y z w' (no unit scaling)"
    },
    {
      "id": "movie-pos",
      "label": "movie-pos",
      "description": "Cutscene position: 'x y z rot_deg' (xyz × 4096, w × degrees)"
    },
    {
      "id": "water-height",
      "label": "water-height",
      "description": "Water volumes: 'water wade swim flags [bottom]' (4-5 values)"
    },
    {
      "id": "eco-info",
      "label": "eco-info",
      "description": "Pickup encoding — use the dedicated eco-info / cell-info / buzzer-info formats"
    },
    {
      "id": "cell-info",
      "label": "cell-info",
      "description": "Fuel cell: '(game-task none)' — encodes task ID"
    },
    {
      "id": "buzzer-info",
      "label": "buzzer-info",
      "description": "Scout fly: '(game-task none) index'"
    },
    {
      "id": "symbol",
      "label": "symbol",
      "description": "GOAL symbol reference e.g. 'thunder'"
    },
    {
      "id": "string",
      "label": "string",
      "description": "Plain string value"
    },
    {
      "id": "type",
      "label": "type",
      "description": "GOAL type reference e.g. 'process-drawable'"
    }
  ],

  // ── HardcodedLumpKeys ───────────────────────────────────────────
  "HardcodedLumpKeys": [
    "buzzer-info",
    "cell-info",
    "crate-type",
    "eco-info",
    "idle-distance",
    "name",
    "nav-mesh-sphere",
    "notice-dist",
    "options",
    "path",
    "pathb",
    "sync",
    "vis-dist"
  ],

  // ── HardcodedLumpKeys_notes ─────────────────────────────────────
  "HardcodedLumpKeys_notes": "Keys the exporter always sets automatically. Manual lump rows targeting these emit a warning but aren't blocked — manual value takes priority.",

  // ── AggroEvents ─────────────────────────────────────────────────
  "AggroEvents": [
    {
      "id": "cue-chase",
      "label": "Aggro (chase player)",
      "description": "Wake enemy and start chasing player"
    },
    {
      "id": "cue-patrol",
      "label": "Patrol",
      "description": "Return enemy to patrol state"
    },
    {
      "id": "go-wait-for-cue",
      "label": "Wait for cue (freeze)",
      "description": "Freeze enemy until next cue event"
    }
  ],

  // ── Parents ─────────────────────────────────────────────────────
  "Parents": [
    {
      "etype": "process-drawable",
      "parent": null,
      "description": "Root type for all spawnable entities.",
      "links": {
        "need_task": false,
        "need_path": false,
        "need_nav": false,
        "need_enemy": false,
        "need_vol": false,
        "need_alt": false,
        "need_prev": false,
        "need_next": false,
        "need_sync": false,
        "need_eco-info": false,
        "need_pathb": false
      },
      "lumps": [
        {
          "key": "vis-dist",
          "type": "meters",
          "description": "Distance at which entity stays active/visible. Enemies default 200m."
        },
        {
          "key": "idle-distance",
          "type": "meters",
          "description": "Player must be closer than this to wake the enemy. Default 80m."
        },
        {
          "key": "shadow-mask",
          "type": "uint32",
          "description": "Which shadow layers render for this entity. e.g. 255 = all."
        },
        {
          "key": "light-index",
          "type": "uint32",
          "description": "Index into the level's light array. Controls entity illumination."
        },
        {
          "key": "lod-dist",
          "type": "meters",
          "description": "Distance threshold for LOD switching. Array of floats per LOD level."
        },
        {
          "key": "texture-bucket",
          "type": "int32",
          "description": "Texture bucket for draw calls. Default 1."
        },
        {
          "key": "options",
          "type": "enum-uint32",
          "description": "fact-options bitfield e.g. '(fact-options has-power-cell)'."
        },
        {
          "key": "visvol",
          "type": "vector4m",
          "description": "Visibility bounding box — two vector4m entries (min corner, max corner)."
        }
      ]
    },
    {
      "etype": "nav-enemy",
      "parent": "process-drawable",
      "description": "Enemy that uses nav-mesh pathfinding. Requires a navmesh + a patrol path.",
      "links": {
        "need_path": true,
        "need_nav": true,
        "need_enemy": true
      },
      "link_desc": {
        "desc_path": "REQUIRED. Path indicates the patrol line.",
        "desc_nav": "REQUIRED. Nav-mesh defines where the enemy is able to walk.",
        "desc_enemy": "Controls the AI of the enemy."
      },
      "lumps": [
        {
          "key": "nav-mesh-sphere",
          "type": "vector4m",
          "description": "Fallback nav sphere: 'x y z radius_m'. Auto-injected for nav-unsafe enemies."
        },
        {
          "key": "nav-max-users",
          "type": "int32",
          "description": "Max nav-control users sharing this navmesh. Default 32."
        }
      ]
    },
    {
      "etype": "prop",
      "parent": "process-drawable",
      "description": "Decorative only. No AI, no combat, idle animation only.",
      "links": {},
      "lumps": []
    },
