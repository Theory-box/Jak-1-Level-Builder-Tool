  // ── LumpTypes ───────────────────────────────────────────────────
  "LumpTypes": [
    {
      "id": "float",
      "label": "float",
      "description": "Raw float array — space-separate multiple values e.g. '4.0 0.0 0.15 0.15'"
    },
    {
      "id": "meters",
      "label": "meters",
      "description": "Single float, scaled × 4096. Use for distances in metres"
    },
    {
      "id": "degrees",
      "label": "degrees",
      "description": "Single float, scaled × 182.044. Use for angles in degrees"
    },
    {
      "id": "int32",
      "label": "int32",
      "description": "Signed 32-bit int array — space-separate multiple values"
    },
    {
      "id": "uint32",
      "label": "uint32",
      "description": "Unsigned 32-bit int array — space-separate multiple values"
    },
    {
      "id": "enum-int32",
      "label": "enum-int32",
      "description": "GOAL enum resolved to int32 e.g. '(game-task village1-yakow)'"
    },
    {
      "id": "enum-uint32",
      "label": "enum-uint32",
      "description": "GOAL enum resolved to uint32 e.g. '(fact-options has-power-cell)'"
    },
    {
      "id": "vector4m",
      "label": "vector4m",
      "description": "4-component vector, each × 4096 — 'x y z w'"
    },
    {
      "id": "vector3m",
      "label": "vector3m",
      "description": "3-component vector, each × 4096, w=1 — 'x y z'"
    },
    {
      "id": "vector-vol",
      "label": "vector-vol",
      "description": "Volume vector: 'x y z radius_m' (xyz raw, w × 4096)"
    },
    {
      "id": "vector",
      "label": "vector",
      "description": "4-component raw vector — 'x y z w' (no unit scaling)"
    },
    {
      "id": "movie-pos",
      "label": "movie-pos",
      "description": "Cutscene position: 'x y z rot_deg' (xyz × 4096, w × degrees)"
    },
    {
      "id": "water-height",
      "label": "water-height",
      "description": "Water volumes: 'water wade swim flags [bottom]' (4-5 values)"
    },
    {
      "id": "eco-info",
      "label": "eco-info",
      "description": "Pickup encoding — use the dedicated eco-info / cell-info / buzzer-info formats"
    },
    {
      "id": "cell-info",
      "label": "cell-info",
      "description": "Fuel cell: '(game-task none)' — encodes task ID"
    },
    {
      "id": "buzzer-info",
      "label": "buzzer-info",
      "description": "Scout fly: '(game-task none) index'"
    },
    {
      "id": "symbol",
      "label": "symbol",
      "description": "GOAL symbol reference e.g. 'thunder'"
    },
    {
      "id": "string",
      "label": "string",
      "description": "Plain string value"
    },
    {
      "id": "type",
      "label": "type",
      "description": "GOAL type reference e.g. 'process-drawable'"
    }
  ],

